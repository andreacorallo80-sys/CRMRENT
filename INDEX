  async function leggiPDFconAI(base64Data, fileName, societa) {
    setAiLoading(true);
    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          system: "Sei un assistente per un broker di noleggio a lungo termine (NLT) chiamato Abbonamentiauto.it. 
Leggi il documento allegato (PDF di una societa di noleggio) e genera un brief operativo per i commerciali.
Rispondi SOLO con il brief, in italiano, strutturato cosi:
- Titolo con emoji della societa
- PUNTI CHIAVE: lista bullet dei vantaggi/novita principali
- TARGET CONSIGLIATO: che tipo di lead/cliente e piu adatto
- URGENZA: se ci sono scadenze o disponibilita limitate
- MESSAGGIO COMMERCIALE SUGGERITO: un messaggio breve (max 2 righe) che il commerciale puo inviare via WhatsApp al cliente
Sii conciso, pratico, orientato alla vendita.",
          messages: [{
            role: "user",
            content: [
              { type: "document", source: { type: "base64", media_type: "application/pdf", data: base64Data } },
              { type: "text", text: "Analizza questo documento di " + societa + " (file: " + fileName + ") e genera il brief commerciale per il team di vendita NLT." }
            ]
          }]
        })
      });
      const data = await response.json();
      const testo = data.content?.map(b => b.text || "").join("\n") || "Impossibile leggere il documento.";
      setAiLoading(false);
      return testo;
    } catch (e) {
      setAiLoading(false);
      return "Errore nella lettura AI del documento. Riprova o inserisci il riassunto manualmente.";
    }
  }

