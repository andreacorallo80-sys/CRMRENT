function Chip({ label, color }) {
  return <span style={{ background:color+"22", color, border:"1px solid " + color + "44", borderRadius:6, padding:"2px 10px", fontSize:11, fontWeight:700, whiteSpace:"nowrap" }}>{label}</span>;
}

function Kpi({ label, value, sub, color, icon, alert }) {
  return (
    <div style={{ background:"linear-gradient(135deg,#0d1929,#112240)", border:"1px solid " + alert?\"#ef444466\":\"#1e293b\", borderRadius:14, padding:"16px 18px", position:"relative", overflow:"hidden" }}>
      {alert && <div style={{ position:"absolute", top:0, left:0, right:0, height:3, background:"#ef4444" }} />}
      <div style={{ position:"absolute", top:10, right:12, fontSize:22, opacity:.12 }}>{icon}</div>
      <div style={{ color:"#475569", fontSize:10, fontWeight:700, letterSpacing:1, textTransform:"uppercase", marginBottom:5 }}>{label}</div>
      <div style={{ color:alert?"#ef4444":color, fontSize:26, fontWeight:900, fontFamily:"monospace" }}>{value}</div>
      {sub && <div style={{ color:"#475569", fontSize:11, marginTop:4 }}>{sub}</div>}
    </div>
  );
}

function validaPratica(opp) {
  if (!opp) return { valida:false, pct:0, campiMancanti:[] };
  const cp = ["veicolo","mesi","km","canone","societaNLT"];
  const compilati = cp.filter(c => c==="societaNLT" ? opp.societaNLT?.length>=3 : opp[c] && opp[c]!=="");
  const pct = Math.round((compilati.length/cp.length)*100);
  return { valida:pct>=80, pct, campiMancanti:cp.filter(c=>!compilati.includes(c)) };
}

