function getTempoProduzione(veicolo) {
  if (!veicolo) return null;
  const lower = veicolo.toLowerCase();
  return TEMPI_PRODUZIONE_PLACEHOLDER.find(t =>
    lower.includes(t.marca.toLowerCase()) || lower.includes(t.modello.toLowerCase())
  ) || null;
}

function getTempoConsegna(societaNLT, vetturaDaOrdinare) {
  const t = TEMPI_CONSEGNA_SOCIETA[societaNLT];
  if (!t) return "-";
  return vetturaDaOrdinare ? t.ordine : t.stock;
}

