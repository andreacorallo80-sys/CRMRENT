                </div>
                <div className="card" style={{ padding:16 }}>
                  <div style={{ fontWeight:700, color:"#e2e8f0", marginBottom:11 }}>Campagna Survey Targetizzata</div>
                  <p style={{ fontSize:12, color:"#475569", lineHeight:1.6, marginBottom:13 }}>Seleziona un interesse e invia una promo a tutti i lead non convertiti ma non avevano convertito.</p>
                  <div style={{ display:"flex", flexDirection:"column", gap:8 }}>
                    <select><option>Seleziona marca/modello interesse</option><option>Audi</option><option>BMW</option><option>Mercedes</option><option>Volkswagen</option><option>Tesla</option></select>
                    <select><option>Tutti i motivi NQ</option>{MOTIVI_NQ.map(m=><option key={m}>{m}</option>)}</select>
                    <input placeholder="Oggetto email / WA promo" />
                    <textarea rows={3} placeholder="Testo messaggio promo..." />
                    <button className="bp" onClick={()=>toast("[GO] Campagna survey lanciata!")}>[GO] Lancia Campagna</button>
                  </div>
                </div>
              </div>
              <div className="card" style={{ overflow:"hidden" }}>
                <div style={{ padding:"14px 16px", borderBottom:"1px solid #0f1e38", fontWeight:700, color:"#e2e8f0" }}>Lead Non Qualificate</div>
                <table style={{ width:"100%", borderCollapse:"collapse" }}>
                  <thead><tr><th>Cliente</th><th>Motivo NQ</th><th>Note</th><th>Data</th><th>Azioni</th></tr></thead>
                  <tbody>
                    {leads.filter(l=>l.stato==="non_qualificata").map(l=>(
                      <tr key={l.id} className="rh">
                        <td style={{ fontWeight:700, color:"#e2e8f0" }}>{l.nome}</td>
                        <td><Chip label={l.motivoNQ||"-"} color="#ef4444" /></td>
                        <td style={{ fontSize:11, color:"#64748b" }}>{l.note||"-"}</td>
                        <td style={{ fontSize:10, color:"#475569", fontFamily:"monospace" }}>{l.dataCreazione}</td>
                        <td>
                          <div style={{ display:"flex", gap:6 }}>
                            <button className="bg" onClick={()=>toast("[MSG] Offerta inviata a ${l.nome}")}>[MSG] Offerta</button>
                            <button className="bg" onClick={()=>{ setLeads(ls=>ls.map(x=>x.id===l.id?{...x,stato:"da_gestire",motivoNQ:undefined}:x)); toast("<- Lead rimessa in lavorazione!"); }}><- Riattiva</button>
                          </div>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

        </div>
      </div>

      {/*  MODAL NQ  */}
      {modalNQ&&(
        <div className="mo" onClick={()=>setModalNQ(null)}>
          <div className="card si" style={{ width:400, padding:22 }} onClick={e=>e.stopPropagation()}>
            <div style={{ fontWeight:800, fontSize:15, color:"#f1f5f9", marginBottom:4 }}>Chiudi come Non Qualificata</div>
            <div style={{ color:"#475569", fontSize:12, marginBottom:16 }}>{modalNQ.nome} - seleziona il motivo</div>
            {MOTIVI_NQ.map(m=>(
              <button key={m} onClick={()=>nonQualifica(modalNQ,m)} style={{ background:"#0a1628", color:"#ef4444", border:"1px solid #ef444433", borderRadius:8, padding:"9px 14px", fontSize:12, fontWeight:600, textAlign:"left", width:"100%", marginBottom:6 }}> {m}</button>
            ))}
            <button className="bg" style={{ width:"100%", marginTop:4 }} onClick={()=>setModalNQ(null)}>Annulla</button>
          </div>
        </div>
      )}

      {/*  MODAL NUOVA OPP  */}
      {modalOpp&&(
        <div className="mo" onClick={()=>setModalOpp(null)}>
          <div className="card si" style={{ width:440, padding:22 }} onClick={e=>e.stopPropagation()}>
            <div style={{ fontWeight:800, fontSize:15, color:"#f1f5f9", marginBottom:4 }}>Nuova Opportunita</div>
            <div style={{ color:"#475569", fontSize:12, marginBottom:16 }}>Cliente: <strong style={{ color:"#e2e8f0" }}>{modalOpp.nome}</strong></div>
            <div style={{ display:"flex", flexDirection:"column", gap:9 }}>
              <input placeholder="Veicolo (es. BMW X3 xDrive20d)" value={oppForm.veicolo} onChange={e=>setOppForm(s=>({...s,veicolo:e.target.value}))} />
              <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr 1fr", gap:8 }}>
                <input type="number" placeholder="Mesi" value={oppForm.mesi} onChange={e=>setOppForm(s=>({...s,mesi:e.target.value}))} />
                <input type="number" placeholder="KM/anno" value={oppForm.km} onChange={e=>setOppForm(s=>({...s,km:e.target.value}))} />
                <input type="number" placeholder="Canone /m" value={oppForm.canone} onChange={e=>setOppForm(s=>({...s,canone:e.target.value}))} />
              </div>
              <select value={oppForm.tipo} onChange={e=>setOppForm(s=>({...s,tipo:e.target.value}))}>
                <option>Full Service</option><option>Manutenzione</option><option>Base</option>
              </select>
            </div>
            <div style={{ display:"flex", gap:9, marginTop:16 }}>
              <button className="bg" style={{ flex:1 }} onClick={()=>setModalOpp(null)}>Annulla</button>
              <button className="bp" style={{ flex:1 }} onClick={()=>creaOpp(modalOpp)}>Crea Opportunita</button>
            </div>
          </div>
        </div>
      )}

      {/*  MODAL NUOVA LEAD  */}
      {modalLead&&(
        <div className="mo" onClick={()=>setModalLead(false)}>
          <div className="card si" style={{ width:440, padding:22 }} onClick={e=>e.stopPropagation()}>
            <div style={{ fontWeight:800, fontSize:15, color:"#f1f5f9", marginBottom:4 }}>+ Nuova Lead</div>
            <div style={{ color:"#475569", fontSize:12, marginBottom:16 }}>Inserimento manuale - Round Robin automatico</div>
            <div style={{ display:"flex", flexDirection:"column", gap:9 }}>
              <input placeholder="Nome Cognome *" value={newLead.nome} onChange={e=>setNewLead(s=>({...s,nome:e.target.value}))} />
              <select value={newLead.tipo} onChange={e=>setNewLead(s=>({...s,tipo:e.target.value}))}>
                <option value="privato">Persona Fisica (PF)</option>
                <option value="piva">P.IVA / Azienda</option>
                <option value="libero_professionista">Libero Professionista</option>
              </select>
              {newLead.tipo!=="privato"&&<input placeholder="Ragione Sociale" value={newLead.azienda} onChange={e=>setNewLead(s=>({...s,azienda:e.target.value}))} />}
              <input placeholder="Email *" value={newLead.email} onChange={e=>setNewLead(s=>({...s,email:e.target.value}))} />
              <input placeholder="Cellulare" value={newLead.cellulare} onChange={e=>setNewLead(s=>({...s,cellulare:e.target.value}))} />
              <select value={newLead.fonte} onChange={e=>setNewLead(s=>({...s,fonte:e.target.value}))}>
                {["Facebook Ads","Google Ads","LinkedIn","Instagram","Sito Web","Referral","Email"].map(f=><option key={f}>{f}</option>)}
              </select>
              <textarea rows={2} placeholder="Note iniziali..." value={newLead.note} onChange={e=>setNewLead(s=>({...s,note:e.target.value}))} />
            </div>
            <div style={{ display:"flex", gap:9, marginTop:16 }}>
              <button className="bg" style={{ flex:1 }} onClick={()=>setModalLead(false)}>Annulla</button>
              <button className="bp" style={{ flex:1 }} onClick={addLead}>Crea + Assegna</button>
            </div>
          </div>
        </div>
      )}

      {/*  MODAL NUOVA INIZIATIVA  */}
      {showNuovaIniz&&(
        <div className="mo" onClick={()=>setShowNuovaIniz(false)}>
          <div className="card si" style={{ width:500, padding:24 }} onClick={e=>e.stopPropagation()}>
            <div style={{ display:"flex", gap:10, alignItems:"center", marginBottom:4 }}>
              <div style={{ width:32, height:32, borderRadius:9, background:"linear-gradient(135deg,#1d4ed8,#7c3aed)", display:"flex", alignItems:"center", justifyContent:"center", fontSize:15 }}>[FOLDER]</div>
              <div>
                <div style={{ fontWeight:800, fontSize:15, color:"#f1f5f9" }}>Carica Nuova Iniziativa</div>
                <div style={{ fontSize:11, color:"#475569" }}>L&#39;AI leggera il PDF e generera il brief per i commerciali</div>
              </div>
            </div>
            <div style={{ background:"#0a1628", border:"1px solid #2563eb33", borderRadius:9, padding:"10px 14px", marginBottom:16, marginTop:12, fontSize:11, color:"#60a5fa" }}>
              [AI] Il sistema usera Claude AI per leggere il PDF della societa di noleggio ed estrarre automaticamente: punti chiave, target consigliato, urgenze e messaggio commerciale suggerito.
            </div>
            <div style={{ display:"flex", flexDirection:"column", gap:10 }}>
              <div>
                <div style={{ fontSize:10, color:"#334155", fontWeight:700, textTransform:"uppercase", letterSpacing:.5, marginBottom:5 }}>Titolo Iniziativa</div>
                <input placeholder="Es. Promo Estate 2026 - Arval" value={inizForm.titolo} onChange={e=>setInizForm(s=>({...s,titolo:e.target.value}))} />
              </div>
              <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:10 }}>
                <div>
                  <div style={{ fontSize:10, color:"#334155", fontWeight:700, textTransform:"uppercase", letterSpacing:.5, marginBottom:5 }}>Societa NLT</div>
                  <select value={inizForm.societa} onChange={e=>setInizForm(s=>({...s,societa:e.target.value}))}>
                    {SOCIETA_NLT.map(s=><option key={s}>{s}</option>)}
                  </select>
                </div>
                <div>
                  <div style={{ fontSize:10, color:"#334155", fontWeight:700, textTransform:"uppercase", letterSpacing:.5, marginBottom:5 }}>Tipo</div>
                  <select value={inizForm.tipo} onChange={e=>setInizForm(s=>({...s,tipo:e.target.value}))}>
                    {["Promo stagionale","Listino","Offerta speciale","Aggiornamento prodotto","Comunicazione interna"].map(t=><option key={t}>{t}</option>)}
                  </select>
                </div>
              </div>
              <div>
                <div style={{ fontSize:10, color:"#334155", fontWeight:700, textTransform:"uppercase", letterSpacing:.5, marginBottom:5 }}>Mese di Riferimento</div>
                <input placeholder="Es. Giugno 2026" value={inizForm.mese} onChange={e=>setInizForm(s=>({...s,mese:e.target.value}))} />
              </div>

              {/* Upload PDF */}
              <div>
                <div style={{ fontSize:10, color:"#334155", fontWeight:700, textTransform:"uppercase", letterSpacing:.5, marginBottom:5 }}>File PDF</div>
                <input
                  type="file"
                  accept=".pdf"
                  ref={fileInputRef}
                  style={{ display:"none" }}
                  onChange={async e=>{
                    const file = e.target.files[0];
                    if(!file) return;
                    setInizForm(s=>({...s,fileName:file.name}));
                    const reader = new FileReader();
                    reader.onload = ev => setPdfBase64(ev.target.result.split(",")[1]);
                    reader.readAsDataURL(file);
                  }}
                />
                <div
                  onClick={()=>fileInputRef.current?.click()}
                  style={{ background:"#0a1628", border:"2px dashed " + pdfBase64?\"#10b981\":\"#1a2e4a\", borderRadius:10, padding:"18px", textAlign:"center", cursor:"pointer", transition:"all .15s" }}
                >
                  {pdfBase64
                    ? <div style={{ color:"#10b981", fontWeight:700, fontSize:13 }}>OK {inizForm.fileName}</div>
                    : <div>
                        <div style={{ fontSize:24, marginBottom:6 }}>[FILE]</div>
                        <div style={{ fontSize:13, color:"#64748b", fontWeight:600 }}>Clicca per caricare il PDF</div>
                        <div style={{ fontSize:11, color:"#334155", marginTop:3 }}>Listino, promo, offerta della societa NLT</div>
                      </div>
                  }
                </div>
              </div>
            </div>

            <div style={{ display:"flex", gap:10, marginTop:18 }}>
              <button className="bg" style={{ flex:1 }} onClick={()=>{ setShowNuovaIniz(false); setPdfBase64(null); }}>Annulla</button>
              <button
                className="bp"
                style={{ flex:2, opacity: (!pdfBase64||aiLoading)?0.6:1 }}
                disabled={!pdfBase64||aiLoading}
                onClick={()=>{ if(pdfBase64) caricaInizCon(pdfBase64, inizForm.fileName); }}
              >
                {aiLoading ? "[AI] AI sta leggendo il PDF..." : "[AI] Carica e Analizza con AI"}
              </button>
            </div>
            {aiLoading&&(
              <div style={{ marginTop:12, background:"#0f2d52", border:"1px solid #2563eb33", borderRadius:8, padding:"10px 14px" }}>
                <div style={{ display:"flex", gap:10, alignItems:"center" }}>
                  <div className="pulse" style={{ width:8, height:8, borderRadius:"50%", background:"#2563eb", flexShrink:0 }} />
                  <div style={{ fontSize:12, color:"#60a5fa" }}>Claude sta leggendo il documento e generando il brief commerciale...</div>
                </div>
              </div>
            )}
          </div>
        </div>
      )}

      {/*  TOAST  */}
      {notif&&(
        <div style={{ position:"fixed", bottom:20, right:20, background:"linear-gradient(135deg,#0a1628,#0f1f3a)", border:"1px solid " + notifType==="error"?"#ef4444":notifType==="warn"?"#f59e0b":"#10b981" + "44", borderRadius:11, padding:"12px 18px", color:"#e2e8f0", fontSize:13, fontWeight:600, boxShadow:"0 8px 30px rgba(0,0,0,.5)", zIndex:200, maxWidth:400, animation:"si .2s ease" }}>
          {notif}
        </div>
      )}
    </div>
  );
}
